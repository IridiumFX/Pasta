; Web server configuration
{
  bind: "0.0.0.0",
  port: 8080,
  workers: 4,
  routes: [
    {path: "/api/users", method: "GET"},
    {path: "/api/users", method: "POST"},
    {path: "/api/users/:id", method: "GET"},
    {path: "/api/health", method: "GET"}
  ],
  cors: {
    enabled: true,
    origins: ["https://app.example.com", "https://admin.example.com"],
    max_age: 86400
  },
  tls: {
    enabled: false,
    cert_path: null,
    key_path: null
  }
}
